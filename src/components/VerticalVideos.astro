// 01. Vídeos verticales — self-hosted (public/videos), divididos en dos carruseles: Gaming y Dance.
// Cada tarjeta muestra un póster liviano; el vídeo se carga sólo al abrir el modal (preload diferido).
// El modal reproduce el clip local + muestra info y los enlaces a cada plataforma original.
// La interacción (coverflow + hover + arrastre + modal) vive en la island de React
// `VerticalGallery`, animada con Framer Motion.
import VerticalGallery from './VerticalGallery.tsx';
import TypeIn from './TypeIn.tsx';

type Cat = 'gaming' | 'dance' | 'informativos';
type Tier = 'compleja' | 'intermedia' | 'basica'; // nivel de edición
type Platform = 'youtube' | 'tiktok' | 'instagram';
interface Link {
	platform: Platform;
	url: string;
	views?: string;
}
interface Vid {
	slug: string; // basename del vídeo y del póster
	title: string;
	cat: Cat;
	views?: string; // dato destacado (el más alto)
	tier?: Tier; // nivel de edición (se asigna desde tierBySlug)
	summary?: string; // formato / tipo de edición (una línea)
	details?: string[]; // qué incluye la edición (técnicas, orden homogéneo)
	coming?: boolean; // tarjeta "Próximamente" (placeholder, sin vídeo real)
	links: Link[];
}

