<div id="vertical" style="position:relative;margin-top:34px;">
	<div style="display:flex;align-items:center;gap:22px;margin-bottom:26px;">
		<TypeIn
			client:visible
			text="01. VÍDEOS VERTICALES"
			style={{ margin: 0, fontWeight: 600, fontSize: '25px', letterSpacing: '1px', whiteSpace: 'nowrap' }}
		/>
		<span style="flex:1;height:1px;background:rgba(255,255,255,.22);"></span>
	</div>

	<div data-reveal="fade">
		<VerticalGallery client:visible groups={groups} />
	</div>
</div>

<!-- Estilos GLOBALes: la island de React no recibe el data-astro-cid del scope,
     así que sus clases (.vt-*) deben declararse globales para que apliquen. -->
<style is:global>
	.vt-group {
		margin-bottom: 30px;
	}
	.vt-group-head {
		display: flex;
		align-items: center;
		gap: 10px;
		font-family: 'Space Mono', monospace;
		font-size: 12px;
		letter-spacing: 2px;
		color: #d8d6d0;
		margin-bottom: 8px;
	}
	.vt-dot {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		flex: none;
	}
	.vt-dot.cat-gaming {
		background: #cf2e2e;
	}
	.vt-dot.cat-dance {
		background: #7c4dd6;
	}
	.vt-count {
		font-size: 10px;
		color: #7a7873;
		letter-spacing: 1px;
	}

	/* ===== Coverflow: 3 piezas en foco + 2 por detrás a cada lado ===== */
	.vt-coverflow {
		position: relative;
		height: 348px;
		margin-top: 4px;
		/* deja asomar las piezas de atrás por los costados */
		overflow: visible;
		touch-action: pan-y;
		user-select: none;
	}
	.vt-card {
		position: absolute;
		left: 50%;
		top: 50%;
		width: 188px;
		margin: 0;
		padding: 0;
		border: 0;
		font: inherit;
		color: inherit;
		text-align: left;
		background: #0e0e0f;
		cursor: pointer;
		transform-origin: center center;
		box-shadow: 0 18px 42px rgba(0, 0, 0, 0.55);
		/* Posición/escala/opacidad las controla Framer Motion (motion values);
		   sólo el filtro de enfoque sigue siendo una transición CSS. */
		transition: filter 0.55s ease;
	}
	.vt-card:focus-visible {
		outline: 2px solid #cf2e2e;
		outline-offset: 2px;
	}
	/* Las piezas que NO están en foco se ven más apagadas (refuerza el enfoque). */
	.vt-card:not(.is-focus) {
		filter: brightness(0.6) saturate(0.55);
	}
	.vt-card:not(.is-focus) .vt-meta {
		opacity: 0;
	}
	@media (prefers-reduced-motion: reduce) {
		.vt-card {
			transition: none;
		}
	}
	.vt-thumb {
		position: relative;
		width: 100%;
		aspect-ratio: 9 / 16;
		overflow: hidden;
		background: #0e0e0f;
		display: block;
	}
	.vt-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		filter: grayscale(1);
		transition: filter 0.45s ease;
	}
