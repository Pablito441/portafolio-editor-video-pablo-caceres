---
// Sección hero: ocupa toda la pantalla al cargar y centra su contenido.
// Las animaciones de entrada son 100% CSS (@keyframes) para que arranquen de
// forma INSTANTÁNEA en el primer pintado, sin esperar a que cargue ningún JS.
// Antes esto era una island de React con Framer Motion (client:load): el Hero
// quedaba invisible (opacity:0) hasta que descargaba/ejecutaba ese JS pesado,
// lo que provocaba varios segundos de retardo en la primera visita.
// Cada pieza entra desde una dirección distinta en cascada, igual que antes.
const tools = [
	{ name: 'Premiere Pro', src: '/images/logos/premiere.webp' },
	{ name: 'Photoshop', src: '/images/logos/photoshop.webp' },
	{ name: 'CapCut', src: '/images/logos/capcut.webp' },
	{ name: 'After Effects', src: '/images/logos/aftereffects.webp' },
];
---

<section
	id="inicio"
	style="position:relative;min-height:calc(100vh - 78px);display:flex;align-items:center;box-sizing:border-box;"
>
	<div
		class="hero-inner"
		style="position:relative;width:100%;min-height:470px;padding:18px 104px 36px 96px;box-sizing:border-box;"
	>
		{/* columna izquierda */}
		<div class="hero-left" style="position:relative;z-index:2;max-width:470px;">
			{/* eyebrow — desde ARRIBA */}
			<div
				class="hero-anim"
				style="--hero-from:translateY(-40px);--hero-delay:0.1s;display:flex;align-items:flex-start;gap:6px;font-weight:500;font-size:17px;letter-spacing:4px;color:#eceae4;margin-bottom:8px;"
			>
				EDITOR &amp; FILMMAKER
				<svg width="11" height="11" viewBox="0 0 12 12" style="margin-top:1px;opacity:0.8;">
					<circle cx="6" cy="6" r="4.5" stroke="#cf2e2e" stroke-width="1" fill="none" />
					<line x1="6" y1="1.5" x2="6" y2="10.5" stroke="#cf2e2e" stroke-width="1" />
					<line x1="1.5" y1="6" x2="10.5" y2="6" stroke="#cf2e2e" stroke-width="1" />
				</svg>
			</div>

			{/* título animado — desde la IZQUIERDA */}
			<video
				class="hero-anim hero-title"
				style="--hero-from:translateX(-70px);--hero-delay:0.22s;width:452px;max-width:none;display:block;margin:2px 0px 6px -17px;mix-blend-mode:screen;"
				src="/videos/titulo.mp4"
				autoplay
				muted
				loop
				playsinline
				preload="metadata"
				poster="/images/titulo-editor.png"
				aria-label="EDITOR DE VIDEO"></video>

			{/* claim — desde la IZQUIERDA */}
			<div
				class="hero-anim"
				style="--hero-from:translateX(-50px);--hero-delay:0.34s;display:flex;align-items:center;gap:11px;margin:10px 0 18px;"
			>
				<span
					style="width:0;height:0;border-style:solid;border-width:7px 0 7px 11px;border-color:transparent transparent transparent #cf2e2e;"
				></span>
				<span style="font-weight:600;font-size:15px;letter-spacing:3px;color:#eceae4;"
					>YOUTUBE, REELS, SHORTS y TIKTOKS</span
				>
			</div>

			{/* párrafo — desde ABAJO */}
			<p
				class="hero-anim"
				style="--hero-from:translateY(40px);--hero-delay:0.44s;font-weight:300;font-size:15px;line-height:1.55;color:#b6b4ae;max-width:255px;margin:0 0 26px;"
			>
				Videos dinámicos, claros y con ritmo, diseñados para captar la atención,
				aumentar la retención y mantener al espectador mirando hasta el final.
			</p>

			{/* CTA + chips */}
			<div class="hero-cta-row" style="display:flex;align-items:center;gap:18px;">
				<a
					href="#vertical"
					class="dc-btn hero-anim"
					style="--hero-from:translateY(40px);--hero-delay:0.54s;display:flex;align-items:center;gap:34px;padding:15px 22px;font-weight:600;font-size:13px;letter-spacing:2px;"
				>
					VER TRABAJOS
					<svg width="30" height="10" viewBox="0 0 30 10" fill="none">
						<line x1="0" y1="5" x2="26" y2="5" stroke="#f0eee8" stroke-width="1" />
						<polyline points="21,1 26,5 21,9" stroke="#f0eee8" stroke-width="1" fill="none" />
					</svg>
				</a>

				{/* chips: entran uno a uno (pop) con delays escalonados */}
				<div style="display:flex;gap:10px;">
					{
						tools.map((tool, i) => (
							<span
								class="tool-chip hero-anim-pop"
								title={tool.name}
								style={`--hero-from:scale(0.4) translateY(14px);--hero-delay:${0.62 + i * 0.08}s;`}
							>
								<img
									src={tool.src}
									alt={tool.name}
									width="36"
									height="36"
									loading="lazy"
									decoding="async"
								/>
							</span>
						))
					}
				</div>
			</div>
		</div>

		{/* garabato junto al título — aparece con escala/fade */}
		<svg
			class="hero-anim hero-scribble"
			style="--hero-from:scale(0.6);--hero-delay:0.5s;--hero-opacity:0.85;position:absolute;left:392px;top:58px;z-index:1;opacity:0.85;"
			width="80"
			height="46"
			viewBox="0 0 80 46"
		>
			<path
				d="M3 30 C25 8, 40 6, 70 16 M10 38 C30 18, 48 16, 74 24 M20 44 C36 30, 52 26, 66 30"
				stroke="#d8d6d0"
				stroke-width="1.4"
				fill="none"
				stroke-linecap="round"
			></path>
		</svg>

		{/* collage derecha — entra desde la DERECHA; hover: escala suave */}
		<img
			class="hero-anim hero-collage"
			style="--hero-from:translateX(80px);--hero-delay:0.3s;position:absolute;top:8px;right:106px;width:360px;z-index:1;"
			src="/images/hero-collage.webp"
			alt=""
		/>

		{/* insignia rotatoria — entra con escala (pop), luego gira (CSS) */}
		<div
			class="hero-anim hero-badge"
			style="--hero-from:scale(0.5);--hero-delay:0.72s;position:absolute;top:212px;right:84px;width:78px;height:78px;z-index:3;"
		>
			<svg viewBox="0 0 100 100" width="78" height="78" style="animation:spin 20s linear infinite;">
				<defs>
					<path
						id="badgepath"
						d="M50,50 m-37,0 a37,37 0 1,1 74,0 a37,37 0 1,1 -74,0"
						fill="none"
					></path>
				</defs>
				<text
					font-family="'Space Mono',monospace"
					font-size="9.5"
					letter-spacing="1.5"
					fill="rgba(235,233,227,.6)"
				>
					<textPath href="#badgepath" startOffset="0%">EDITOR · FILMMAKER · VIDEÓGRAFO · </textPath>
				</text>
			</svg>
			<span
				style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px;letter-spacing:1px;color:#eceae4;font-style:italic;"
				>PC</span
			>
		</div>
	</div>
</section>

<style>
	/* ===== Entrada del Hero: 100% CSS → arranca en el primer frame, sin JS =====
	   Cada elemento define su punto de partida (--hero-from) y su retardo
	   (--hero-delay) inline, replicando el helper appear(from, delay) que antes
	   estaba en Framer Motion. */
	@keyframes heroIn {
		from {
			opacity: 0;
			transform: var(--hero-from, none);
		}
		to {
			opacity: var(--hero-opacity, 1);
			transform: none;
		}
	}

	/* `backwards`: mantiene el estado inicial (invisible) durante el delay y, al
	   terminar, devuelve el control al CSS normal → los :hover siguen andando. */
	.hero-anim {
		animation: heroIn 0.7s cubic-bezier(0.22, 0.61, 0.36, 1) backwards;
		animation-delay: var(--hero-delay, 0s);
	}

	/* chips: mismo esquema pero con un rebote (pop) al entrar */
	.hero-anim-pop {
		animation: heroIn 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
		animation-delay: var(--hero-delay, 0s);
	}

	/* collage: hover con escala suave (antes lo hacía Framer Motion) */
	.hero-collage {
		cursor: pointer;
		transition: transform 0.35s cubic-bezier(0.22, 0.61, 0.36, 1);
	}
	.hero-collage:hover {
		transform: scale(1.03);
	}

	/* ===== Mobile: el hero pasa de layout absoluto a una columna apilada ===== */
	@media (max-width: 760px) {
		#inicio {
			min-height: auto !important;
			align-items: flex-start !important;
		}
		.hero-inner {
			min-height: 0 !important;
			padding: 6px 18px 26px !important;
		}
		.hero-left {
			max-width: 100% !important;
		}
		/* título fluido: nunca más ancho que la pantalla */
		.hero-title {
			width: 100% !important;
			max-width: 440px;
			margin-left: 0 !important;
		}
		/* botón + chips: que puedan pasar a la línea siguiente si no entran */
		.hero-cta-row {
			flex-wrap: wrap !important;
			gap: 16px 18px !important;
		}
		/* el collage pasa a formar parte del flujo, debajo del texto */
		.hero-collage {
			position: static !important;
			width: 100% !important;
			max-width: 340px;
			margin: 28px auto 0 !important;
		}
		/* accesorios decorativos que dependen de posición absoluta: se ocultan */
		.hero-scribble,
		.hero-badge {
			display: none !important;
		}
	}
</style>
