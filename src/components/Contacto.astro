---
// 04. Contacto — datos de contacto (links) y CTA de email.
import TypeIn from './TypeIn.tsx';

const contacts = [
	{
		label: 'WHATSAPP',
		value: '+54 9 261 701 5394',
		href: 'https://wa.me/5492617015394',
		external: true,
		icon: 'whatsapp',
	},
	{
		label: 'EMAIL',
		value: 'pablocaceres441@gmail.com',
		href: 'mailto:pablocaceres441@gmail.com',
		external: false,
		icon: 'email',
	},
	{
		label: 'INSTAGRAM',
		value: '@bliuskii',
		href: 'https://instagram.com/bliuskii',
		external: true,
		icon: 'instagram',
	},
	{
		label: 'X',
		value: '@pabliituss',
		href: 'https://x.com/pabliituss',
		external: true,
		icon: 'x',
	},
];
---

<div id="contacto" style="position:relative;margin-top:60px;padding-bottom:60px;">
	<div style="display:flex;align-items:center;gap:22px;margin-bottom:30px;">
		<TypeIn
			client:visible
			text="05. CONTACTO"
			style={{
				margin: 0,
				fontWeight: 600,
				fontSize: '25px',
				letterSpacing: '1px',
				whiteSpace: 'nowrap',
			}}
		/>
		<span style="flex:1;height:1px;background:rgba(255,255,255,.22);"></span>
	</div>

	<div style="display:flex;align-items:flex-start;justify-content:space-between;gap:30px;">
		<div data-reveal="left" style="flex:none;">
			<h3
				style="margin:0 0 16px;font-weight:600;font-size:30px;line-height:1.02;letter-spacing:.5px;color:#f0eee8;"
			>
				¿TENÉS UN UNA IDEA<br />EN MENTE?
			</h3>
			<p style="margin:0;font-weight:400;font-size:13px;letter-spacing:1px;color:#a8a6a0;">
				HABLEME Y HAGÁMOSLO REALIDAD.
			</p>
		</div>

		<div style="flex:1;display:flex;gap:54px;padding-top:4px;">
			<div style="display:flex;flex-direction:column;gap:22px;">
				{
					contacts
						.filter((c) => c.icon === 'whatsapp' || c.icon === 'email')
						.map((c, i) => (
							<a
								href={c.href}
								class="contact-link"
								data-reveal="right"
								style={`--reveal-delay:${0.12 + i * 0.1}s`}
								target={c.external ? '_blank' : undefined}
								rel={c.external ? 'noopener noreferrer' : undefined}
							>
								<span class="icon-ring" style="width:32px;height:32px;flex:none;">
									{c.icon === 'whatsapp' && (
										<svg width="15" height="15" viewBox="0 0 24 24" fill="none">
											<path
												d="M5 19l1-3.2A8 8 0 1 1 9.2 18L5 19z"
												stroke="#e6e4de"
												stroke-width="1.5"
												stroke-linejoin="round"
											/>
										</svg>
									)}
									{c.icon === 'email' && (
										<svg width="15" height="15" viewBox="0 0 24 24" fill="none">
											<rect x="3" y="5.5" width="18" height="13" rx="1.5" stroke="#e6e4de" stroke-width="1.5" />
											<path d="M4 7l8 6 8-6" stroke="#e6e4de" stroke-width="1.5" fill="none" />
										</svg>
									)}
								</span>
								<div>
									<div style="font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;color:#86847f;">
										{c.label}
									</div>
									<div
										class="contact-val"
										style="font-weight:500;font-size:13px;letter-spacing:.5px;color:#e6e4de;margin-top:3px;white-space:nowrap;"
									>
										{c.value}
									</div>
								</div>
							</a>
						))
				}
			</div>
			<div style="display:flex;flex-direction:column;gap:22px;">
				{
					contacts
						.filter((c) => c.icon === 'instagram' || c.icon === 'x')
						.map((c, i) => (
							<a
								href={c.href}
								class="contact-link"
								data-reveal="right"
								style={`--reveal-delay:${0.32 + i * 0.1}s`}
								target={c.external ? '_blank' : undefined}
								rel={c.external ? 'noopener noreferrer' : undefined}
							>
								<span class="icon-ring" style="width:32px;height:32px;flex:none;">
									{c.icon === 'instagram' && (
										<svg width="15" height="15" viewBox="0 0 24 24" fill="none">
											<rect x="4" y="4" width="16" height="16" rx="4.5" stroke="#e6e4de" stroke-width="1.5" />
											<circle cx="12" cy="12" r="3.6" stroke="#e6e4de" stroke-width="1.5" />
											<circle cx="16.8" cy="7.2" r="1" fill="#e6e4de" />
										</svg>
									)}
									{c.icon === 'x' && (
										<svg width="13" height="13" viewBox="0 0 24 24" fill="none">
											<path
												d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
												fill="#e6e4de"
											/>
										</svg>
									)}
								</span>
								<div>
									<div style="font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;color:#86847f;">
										{c.label}
									</div>
									<div
										class="contact-val"
										style="font-weight:500;font-size:13px;letter-spacing:.5px;color:#e6e4de;margin-top:3px;white-space:nowrap;"
									>
										{c.value}
									</div>
								</div>
							</a>
						))
				}
			</div>
		</div>

		{/* CTA "Escríbeme ahora" desactivado por ahora. Para reactivarlo, borrá esta línea y la de cierre del comentario.
		<a
			href="mailto:pablocaceres441@gmail.com"
			class="dc-btn"
			style="flex:none;width:200px;height:96px;display:flex;flex-direction:column;justify-content:center;padding:0 26px;box-sizing:border-box;"
		>
			<div style="display:flex;align-items:center;justify-content:space-between;">
				<div style="font-weight:600;font-size:20px;letter-spacing:1px;line-height:1.05;">
					ESCRÍBEME<br />AHORA
				</div>
				<svg width="30" height="10" viewBox="0 0 30 10" fill="none" style="margin-top:18px;"
					><line x1="0" y1="5" x2="26" y2="5" stroke="#f0eee8" stroke-width="1"
					></line><polyline points="21,1 26,5 21,9" stroke="#f0eee8" stroke-width="1" fill="none"
					></polyline></svg
				>
			</div>
		</a>
		*/}
	</div>
</div>
