---
// Cabecera: logo, navegación (con scroll-spy) y acciones (redes + "Hablemos").
// En mobile (≤900px) la navegación y las acciones se colapsan en un menú
// desplegable controlado por el botón hamburguesa (sin dependencias).
const navLinks = [
	{ label: 'INICIO', href: '#inicio', active: true },
	{ label: 'VERTICAL', href: '#vertical', active: false },
	{ label: 'HORIZONTALES', href: '#reel', active: false },
	{ label: 'SOBRE MÍ', href: '#sobre', active: false },
	{ label: 'PRECIOS', href: '#precios', active: false },
	{ label: 'CONTACTO', href: '#contacto', active: false },
];
---

<header class="site-header" id="site-header" data-open="false">
	<div class="site-header-inner">
		<div class="logo-block">
			<a href="#inicio" class="logo-link">PABLO<br />CÁCERES</a>
			<svg width="20" height="20" viewBox="0 0 20 20" style="opacity:.7"
				><circle cx="10" cy="10" r="6.5" stroke="#bdbbb5" stroke-width="1" fill="none"
				></circle><line x1="10" y1="0" x2="10" y2="20" stroke="#bdbbb5" stroke-width="1"
				></line><line x1="0" y1="10" x2="20" y2="10" stroke="#bdbbb5" stroke-width="1"
				></line></svg
			>
		</div>

		<div class="site-collapse">
			<nav class="site-nav">
				{
					navLinks.map((link) => (
						<a href={link.href} class={link.active ? 'nav-link active' : 'nav-link'}>
							{link.label}
						</a>
					))
				}
			</nav>

			<div class="site-actions">
				<div class="site-social">
					<a
						href="https://instagram.com/bliuskii"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="Instagram"
						class="icon-ring"
						style="width:31px;height:31px;"
					>
						<svg width="15" height="15" viewBox="0 0 24 24" fill="none"
							><rect x="3" y="3" width="18" height="18" rx="5" stroke="#e6e4de" stroke-width="1.6"
							></rect><circle cx="12" cy="12" r="4" stroke="#e6e4de" stroke-width="1.6"
							></circle><circle cx="17.2" cy="6.8" r="1.2" fill="#e6e4de"></circle></svg
						>
					</a>
					<a
						href="https://wa.me/5492617015394"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="WhatsApp"
						class="icon-ring"
						style="width:31px;height:31px;"
					>
						<svg width="15" height="15" viewBox="0 0 24 24" fill="none"
							><path
								d="M5 19l1-3.2A8 8 0 1 1 9.2 18L5 19z"
								stroke="#e6e4de"
								stroke-width="1.5"
								stroke-linejoin="round"></path><path
								d="M9 9.4c0 3 2.6 5.6 5.6 5.6.5 0 .9-.5.6-1l-1-1.4c-.2-.3-.6-.3-.9-.1l-.5.4c-.8-.4-1.5-1.1-1.9-1.9l.4-.5c.2-.3.2-.7-.1-.9L9.4 8c-.5-.3-1 .1-1 .6z"
								fill="#e6e4de"></path></svg
						>
					</a>
					<a
						href="mailto:pablocaceres441@gmail.com"
						aria-label="Email"
						class="icon-ring"
						style="width:31px;height:31px;"
					>
						<svg width="15" height="15" viewBox="0 0 24 24" fill="none"
							><rect x="3" y="5.5" width="18" height="13" rx="1.5" stroke="#e6e4de" stroke-width="1.5"
							></rect><path d="M4 7l8 6 8-6" stroke="#e6e4de" stroke-width="1.5" fill="none"
							></path></svg
						>
					</a>
				</div>
				<a href="#contacto" class="dc-btn hablemos-btn">HABLEMOS</a>
			</div>
		</div>

		<button class="nav-toggle" id="nav-toggle" type="button" aria-label="Abrir menú" aria-expanded="false">
			<span></span><span></span><span></span>
		</button>
	</div>
</header>

<style>
	/* Cabecera fija: siempre visible arriba, sin importar el scroll. */
	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: rgba(8, 8, 10, 0.72);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}
	.site-header-inner {
		position: relative;
		width: 1024px;
		max-width: 100%;
		margin: 0 auto;
		box-sizing: border-box;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 14px 40px;
	}

	.logo-block {
		display: flex;
		align-items: center;
		gap: 14px;
	}
	.logo-link {
		font-family: 'Oswald', sans-serif;
		font-weight: 700;
		font-size: 13px;
		line-height: 1.02;
		letter-spacing: 1px;
		color: #e6e4de;
		text-decoration: none;
	}

	/* En desktop el wrapper "desaparece" (display:contents) → logo | nav | acciones
	   quedan como hijos directos del flex, igual que antes. */
	.site-collapse {
		display: contents;
	}
	.site-nav {
		display: flex;
		align-items: center;
		gap: 20px;
		font-weight: 500;
		font-size: 13px;
		letter-spacing: 1px;
	}
	.site-actions {
		display: flex;
		align-items: center;
		gap: 18px;
	}
	.site-social {
		display: flex;
		gap: 9px;
	}
	.hablemos-btn {
		padding: 13px 24px;
		font-weight: 600;
		font-size: 13px;
		letter-spacing: 2px;
	}

	/* Botón hamburguesa (oculto en desktop) */
	.nav-toggle {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 40px;
		height: 40px;
		padding: 9px;
		box-sizing: border-box;
		background: transparent;
		border: 1px solid rgba(255, 255, 255, 0.18);
		cursor: pointer;
	}
	.nav-toggle span {
		display: block;
		width: 100%;
		height: 2px;
		background: #e6e4de;
		transition:
			transform 0.25s ease,
			opacity 0.2s ease;
	}

	/* ===== Mobile: menú desplegable ===== */
	@media (max-width: 900px) {
		.site-header-inner {
			padding: 12px 22px;
		}
		.nav-toggle {
			display: flex;
		}
		.site-collapse {
			display: none;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			flex-direction: column;
			align-items: stretch;
			gap: 20px;
			padding: 20px 22px 26px;
			background: rgba(8, 8, 10, 0.97);
			backdrop-filter: blur(12px);
			-webkit-backdrop-filter: blur(12px);
			border-bottom: 1px solid rgba(255, 255, 255, 0.08);
		}
		.site-header[data-open='true'] .site-collapse {
			display: flex;
		}
		.site-nav {
			flex-direction: column;
			align-items: flex-start;
			gap: 2px;
			font-size: 15px;
		}
		.site-nav .nav-link {
			display: block;
			width: 100%;
			padding: 11px 0;
		}
		.site-actions {
			justify-content: space-between;
			border-top: 1px solid rgba(255, 255, 255, 0.1);
			padding-top: 18px;
		}
		/* hamburguesa → X cuando el menú está abierto */
		.site-header[data-open='true'] .nav-toggle span:nth-child(1) {
			transform: translateY(7px) rotate(45deg);
		}
		.site-header[data-open='true'] .nav-toggle span:nth-child(2) {
			opacity: 0;
		}
		.site-header[data-open='true'] .nav-toggle span:nth-child(3) {
			transform: translateY(-7px) rotate(-45deg);
		}
	}

	@media (max-width: 640px) {
		.site-header-inner {
			padding: 11px 18px;
		}
	}
</style>

<script>
	const header = document.getElementById('site-header');
	const toggle = document.getElementById('nav-toggle');

	function setOpen(open: boolean) {
		if (!header || !toggle) return;
		header.dataset.open = open ? 'true' : 'false';
		toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
		toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
	}

	toggle?.addEventListener('click', () => {
		setOpen(header?.dataset.open !== 'true');
	});

	// Cerrar el menú al tocar un enlace (nav o acciones).
	header?.querySelectorAll('.site-collapse a').forEach((a) => {
		a.addEventListener('click', () => setOpen(false));
	});

	// Cerrar al volver a desktop y al presionar Escape.
	const mq = window.matchMedia('(min-width: 901px)');
	mq.addEventListener('change', (e) => {
		if (e.matches) setOpen(false);
	});
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') setOpen(false);
	});
</script>
